---
import ProfileIntro from "../components/ProfileIntro.astro";
import RoleList from "../components/RoleList.astro";
import WorkCard from "../components/WorkCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Nikolaos Banis",
  url: "https://www.nikosbanis.com",
  jobTitle: "Senior Product Designer",
  sameAs: ["https://linkedin.com/in/nikosbn"],
  knowsAbout: [
    "Product design",
    "Data visualisation",
    "Design systems",
    "User research",
    "B2B SaaS",
  ],
};
---

<BaseLayout
  title="Nikolaos Banis"
  description="Senior Product Designer creating clear, trustworthy interfaces for complex data products, analytical workflows, and high-stakes decisions."
>
  <script
    slot="head"
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(personSchema)}
  />

  <main id="main-content" class="page">
    <ProfileIntro />
    <RoleList />

    <section aria-labelledby="work-title">
      <h2 id="work-title">Selected work</h2>
      <div class="work-list">
        <WorkCard />
      </div>
    </section>
  </main>
</BaseLayout>
