---
import IdentityHeader from "../components/IdentityHeader.astro";
import IntroSection from "../components/IntroSection.astro";
import PastWorkAccordion from "../components/PastWorkAccordion.astro";
import SelectedWorkList from "../components/SelectedWorkList.astro";
import SiteFooter from "../components/SiteFooter.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Nikolaos Banis",
  url: "https://www.nikosbanis.com",
  jobTitle: "Senior Product Designer",
  sameAs: ["https://linkedin.com/in/nikosbn"],
  knowsAbout: [
    "Product design",
    "Data visualisation",
    "Design systems",
    "Analytical interfaces",
    "Coded prototypes",
  ],
};
---

<BaseLayout
  title="Nikolaos Banis"
  description="Senior Product Designer working on data-heavy products, analytical workflows, design systems, coded prototypes, and implementation-aware product work."
>
  <script
    slot="head"
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(personSchema)}
  />

  <div class="site-frame">
    <div class="site-side" aria-hidden="true"></div>
    <div class="site-page">
      <main id="main-content" class="home-main">
        <div class="home-intro-group">
          <IdentityHeader />
          <IntroSection />
        </div>
        <PastWorkAccordion />
        <SelectedWorkList />
      </main>

      <SiteFooter />
    </div>
    <div class="site-side" aria-hidden="true"></div>
  </div>
</BaseLayout>
