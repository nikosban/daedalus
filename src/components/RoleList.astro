---

<section aria-labelledby="roles-title">
  <h2 id="roles-title">Experience</h2>
  <ol class="role-list">
    {
      roles.map((role) => (
        <li class="role-row">
          <div>
            <h3>{role.position}</h3>
            <p class="meta">{role.company}</p>
          </div>
          <p class="meta role-dates">{role.dates}</p>
        </li>
      ))
    }
  </ol>
</section>
