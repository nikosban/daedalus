---
const roles = [
  {
    position: "Senior Product Designer",
    company: "Statista",
    dates: "Aug 2025 — Present",
  },
  {
    position: "Product Designer",
    company: "Event Inc",
    dates: "Sep 2024 — Feb 2025",
  },
  {
    position: "Senior Product Designer",
    company: "Container xChange",
    dates: "Apr 2022 — Feb 2024",
  },
  {
    position: "UX/UI Designer",
    company: "KINVENT",
    dates: "Jan 2022 — Apr 2024",
  },
  {
    position: "UX/UI Designer",
    company: "CGWorks",
