---
import type { AstroComponent } from "@lucide/astro";

interface Props {
  icon: AstroComponent;
  role?:
    | "inline"
    | "navigation"
    | "control"
    | "disclosure"
    | "metadata"
    | "illustration";
  emphasis?: "default" | "strong";
  optical?: "none" | "up" | "down" | "left" | "right" | "up-right";
  label?: string;
}

const {
  icon: LucideIcon,
  role = "inline",
  emphasis = "default",
  optical = "none",
  label,
} = Astro.props;

const classes = [
  "system-icon",
  `system-icon--${role}`,
  emphasis === "strong" && "system-icon--strong",
  optical !== "none" && `system-icon--optical-${optical}`,
];
---

{
  label ? (
    <LucideIcon
      class:list={classes}
      aria-label={label}
      focusable="false"
      role="img"
    />
  ) : (
    <LucideIcon class:list={classes} aria-hidden="true" focusable="false" />
  )
}
