---
import type { AstroComponent } from "@lucide/astro";

interface Props {
  icon: AstroComponent;
  size?: "text" | "small";
  weight?: "regular" | "medium";
  tone?: "inline" | "current";
  optical?: "none" | "up" | "down" | "left" | "right";
  label?: string;
}

const {
  icon: LucideIcon,
  size = "text",
  weight = "regular",
  tone = "inline",
  optical = "none",
  label,
} = Astro.props;
---

{
  label ? (
    <LucideIcon
      class:list={[
        "system-icon",
        `system-icon--${size}`,
        `system-icon--${weight}`,
        `system-icon--${tone}`,
        optical !== "none" && `system-icon--optical-${optical}`,
      ]}
      aria-label={label}
    />
  ) : (
    <LucideIcon
      class:list={[
        "system-icon",
        `system-icon--${size}`,
        `system-icon--${weight}`,
        `system-icon--${tone}`,
        optical !== "none" && `system-icon--optical-${optical}`,
      ]}
    />
  )
}
