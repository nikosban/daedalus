---
interface Props {
  title?: string;
  date?: string;
  description?: string;
}

const {
  title = "Redesigning how people explore statistical data",
  date = "2025 — Present",
  description = "A new statistics experience for researchers and analysts, designed to improve data exploration across more than one million pages.",
} = Astro.props;
---

<details class="work-card">
  <summary>
    <span class="work-card-heading">
      <span class="work-title">{title}</span>
      <span class="meta">{date}</span>
    </span>

    <span class="image-placeholder" aria-label="Project image placeholder" role="img">
      <span class="meta" aria-hidden="true">Project image</span>
    </span>

    <span class="work-description">{description}</span>
  </summary>
  <p class="work-status meta">Full case study in progress.</p>
</details>
